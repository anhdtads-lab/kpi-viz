{
  "name": "kpi_bullet_chart",
  "organization": "German Link",
  "description": "So sánh KPI thực tế vs mục tiêu tháng, quý, năm",
  "logoUrl": "",
  "organizationUrl": "https://germanlink.vn",
  "supportUrl": "https://germanlink.vn",
  "privacyPolicyUrl": "https://germanlink.vn",
  "termsOfServiceUrl": "https://germanlink.vn",
  "packageUrl": "",
  "devMode": false,
  "components": [
    {
      "id": "kpiBullet",
      "name": "KPI Bullet Chart",
      "description": "So sánh thực tế vs mục tiêu tháng / quý / năm",
      "iconUrl": "",
      "resource": {
        "js": "index.js",
        "css": "index.css"
      },
      "data": [
        {
          "id": "concepts",
          "label": "Dữ liệu KPI",
          "elements": [
            {
              "id": "dimKPI",
              "label": "Tên KPI",
              "type": "DIMENSION",
              "options": {
                "min": 1,
                "max": 1,
                "supportedTypes": ["TEXT"]
              }
            },
            {
              "id": "metActual",
              "label": "Thực tế",
              "type": "METRIC",
              "options": { "min": 1, "max": 1 }
            },
            {
              "id": "metMonthly",
              "label": "Mục tiêu Tháng",
              "type": "METRIC",
              "options": { "min": 0, "max": 1 }
            },
            {
              "id": "metQuarterly",
              "label": "Mục tiêu Quý",
              "type": "METRIC",
              "options": { "min": 0, "max": 1 }
            },
            {
              "id": "metYearly",
              "label": "Mục tiêu Năm",
              "type": "METRIC",
              "options": { "min": 0, "max": 1 }
            }
          ]
        }
      ],
      "style": [
        {
          "id": "colorConfig",
          "label": "Màu sắc thanh",
          "elements": [
            {
              "id": "colorGood",
              "label": "Đạt mục tiêu (≥ 100%)",
              "type": "FILL_COLOR",
              "defaultValue": { "color": "#34A853" }
            },
            {
              "id": "colorWarning",
              "label": "Gần đạt (80–99%)",
              "type": "FILL_COLOR",
              "defaultValue": { "color": "#FBBC04" }
            },
            {
              "id": "colorBad",
              "label": "Chưa đạt (< 80%)",
              "type": "FILL_COLOR",
              "defaultValue": { "color": "#EA4335" }
            }
          ]
        }
      ]
    }
  ]
}
